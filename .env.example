# ── 模式配置 ──────────────────────────────────────────────────────────────────
# true = 使用 mock LLM（无需 API key，仅开发测试用）
# false = 使用真实 LLM API
MOCK_MODE=true

# ── Anthropic Claude ─────────────────────────────────────────────────────────
# API Key: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-your-key-here
# 可选：指定模型（默认 claude-sonnet-4-5）
ANTHROPIC_MODEL=claude-sonnet-4-5

# ── OpenAI GPT ────────────────────────────────────────────────────────────────
# API Key: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-key-here
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o

# ── DeepSeek ──────────────────────────────────────────────────────────────────
# API Key: https://platform.deepseek.com/
DEEPSEEK_API_KEY=sk-your-key-here
DEEPSEEK_BASE_URL=https://api.deepseek.com
# DeepSeek V3 的 model_id = "deepseek-chat"
DEEPSEEK_MODEL=deepseek-chat

# ── 智谱 GLM ──────────────────────────────────────────────────────────────────
# API Key: https://open.bigmodel.cn/
ZHIPU_API_KEY=your-key-here
ZHIPU_BASE_URL=https://open.bigmodel.cn/api/paas/v4
ZHIPU_MODEL=glm-4-flash

# ── MiniMax ───────────────────────────────────────────────────────────────────
# API Key: https://platform.minimaxi.com/
MINIMAX_API_KEY=your-key-here
MINIMAX_BASE_URL=https://api.minimaxi.com/anthropic
MINIMAX_MODEL=MiniMax-M2

# ── Ollama 本地模型 ────────────────────────────────────────────────────────────
# 无需 API key，免费，需提前安装并启动：ollama serve
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=llama3:8b

# ── 会话配置 ──────────────────────────────────────────────────────────────────
SESSION_DB=./session_store/sessions.db

# 预算上限（每篇论文，CNY）
# BUDGET_CAP_CNY=35.0
